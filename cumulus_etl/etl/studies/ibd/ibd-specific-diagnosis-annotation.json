{
  "$defs": {
    "CDParisBehaviorExclusive": {
      "enum": [
        "B1: nonstricturing, nonpenetrating",
        "B2: stricturing",
        "B3: penetrating",
        "B2B3: both penetrating and stricturing disease, either at the same or different times",
        "Unknown/unclear",
        "Patient does not have a diagnosis of Crohn's disease (CD)"
      ],
      "title": "CDParisBehaviorExclusive",
      "type": "string"
    },
    "CDParisBehaviorExclusiveMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "behavior": {
          "$ref": "#/$defs/CDParisBehaviorExclusive",
          "default": "Patient does not have a diagnosis of Crohn's disease (CD)",
          "description": "What was the Crohn's disease (CD) behavior using the Paris classification?"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "CDParisBehaviorExclusiveMention",
      "type": "object"
    },
    "CDParisBehaviorPerianalModifierMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "perianal_disease": {
          "default": false,
          "description": "Did the patient have Crohn's disease (CD) with perianal disease?",
          "title": "Perianal Disease",
          "type": "boolean"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "CDParisBehaviorPerianalModifierMention",
      "type": "object"
    },
    "CDParisLocationExclusive": {
      "description": "L1, L2, L3 are mutually exclusive, L4a and L4b are not mutually exclusive.",
      "enum": [
        "L1: distal 1/3 ileum +/- limited cecal disease",
        "L2: colonic",
        "L3: ileocolonic",
        "Other location",
        "Unknown/unclear location",
        "Patient does not have a diagnosis of Crohn's disease (CD)"
      ],
      "title": "CDParisLocationExclusive",
      "type": "string"
    },
    "CDParisLocationExclusiveMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "location": {
          "$ref": "#/$defs/CDParisLocationExclusive",
          "default": "Patient does not have a diagnosis of Crohn's disease (CD)",
          "description": "What is the Crohn's disease (CD) location using the Paris classification ?"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "CDParisLocationExclusiveMention",
      "type": "object"
    },
    "CDParisLocationL4aMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "l4a": {
          "default": false,
          "description": "Does the patient have Crohn's disease (CD) with Paris classification L4a: upper disease proximal to the Ligament of Treitz?",
          "title": "L4A",
          "type": "boolean"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "CDParisLocationL4aMention",
      "type": "object"
    },
    "CDParisLocationL4bMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "l4b": {
          "default": false,
          "description": "Does the patient have Crohn's disease (CD) with Paris classification L4b: upper disease distal to the Ligament of Treitz and proximal to distal 1/3 ileum?",
          "title": "L4B",
          "type": "boolean"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "CDParisLocationL4bMention",
      "type": "object"
    },
    "GeneticCause": {
      "enum": [
        "Confirmed pathogenic variant",
        "Likely or suspected pathogenic variant",
        "None of the above"
      ],
      "title": "GeneticCause",
      "type": "string"
    },
    "MonogenicPrimaryMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "ibd_monogenic": {
          "$ref": "#/$defs/GeneticCause",
          "default": "None of the above",
          "description": "Was there a documented genetic cause of IBD?"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "MonogenicPrimaryMention",
      "type": "object"
    },
    "MonogenicSecondaryMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "ibd_monogenic_secondary": {
          "$ref": "#/$defs/GeneticCause",
          "default": "None of the above",
          "description": "Was IBD documented as secondary to a monogenic cause?"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "MonogenicSecondaryMention",
      "type": "object"
    },
    "UCParisLocation": {
      "enum": [
        "E1: ulcerative proctitis",
        "E2: left-sided UC (distal to splenic flexure)",
        "E3: extensive (hepatic flexure distally)",
        "E4: pancolitis (proximal to hepatic flexure)",
        "Unknown/unclear",
        "Patient does not have a diagnosis of UC/IBDU"
      ],
      "title": "UCParisLocation",
      "type": "string"
    },
    "UCParisLocationMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "location": {
          "$ref": "#/$defs/UCParisLocation",
          "default": "Patient does not have a diagnosis of UC/IBDU",
          "description": "What was the ulcerative colitis (UC) Paris classification location?"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "UCParisLocationMention",
      "type": "object"
    },
    "UCParisSeverity": {
      "enum": [
        "S0: never severe",
        "S1: ever severe (PUCAI >/= 65)",
        "Unknown/unclear",
        "Patient does not have a diagnosis of UC/IBDU"
      ],
      "title": "UCParisSeverity",
      "type": "string"
    },
    "UCParisSeverityMention": {
      "properties": {
        "is_present": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Present"
        },
        "spans": {
          "items": {
            "type": "string"
          },
          "title": "Spans",
          "type": "array"
        },
        "severity": {
          "$ref": "#/$defs/UCParisSeverity",
          "default": "Patient does not have a diagnosis of UC/IBDU",
          "description": "What was the ulcerative colitis (UC) Paris classification severity"
        }
      },
      "required": [
        "is_present",
        "spans"
      ],
      "title": "UCParisSeverityMention",
      "type": "object"
    }
  },
  "description": "An object-model for annotations of irritable bowel disorder observations \nfound in a patient's chart, related to specific diagnosis details like \nParis classification and genetic findings.\nTake care to avoid false positives, like confusing information that only\nappears in family history for patient history. Annotations should indicate \nthe relevant details of the finding, as well as some additional evidence\nmetadata to validate findings post-hoc.",
  "properties": {
    "cd_paris_location_exclusive_mention": {
      "$ref": "#/$defs/CDParisLocationExclusiveMention"
    },
    "cd_paris_location_l4a_mention": {
      "$ref": "#/$defs/CDParisLocationL4aMention"
    },
    "cd_paris_location_l4b_mention": {
      "$ref": "#/$defs/CDParisLocationL4bMention"
    },
    "cd_paris_behavior_exclusive_mention": {
      "$ref": "#/$defs/CDParisBehaviorExclusiveMention"
    },
    "cd_paris_behavior_perianal_modifier_mention": {
      "$ref": "#/$defs/CDParisBehaviorPerianalModifierMention"
    },
    "uc_paris_location_mention": {
      "$ref": "#/$defs/UCParisLocationMention"
    },
    "uc_paris_severity_mention": {
      "$ref": "#/$defs/UCParisSeverityMention"
    },
    "monogenic_primary_mention": {
      "$ref": "#/$defs/MonogenicPrimaryMention"
    },
    "monogenic_secondary_mention": {
      "$ref": "#/$defs/MonogenicSecondaryMention"
    }
  },
  "required": [
    "cd_paris_location_exclusive_mention",
    "cd_paris_location_l4a_mention",
    "cd_paris_location_l4b_mention",
    "cd_paris_behavior_exclusive_mention",
    "cd_paris_behavior_perianal_modifier_mention",
    "uc_paris_location_mention",
    "uc_paris_severity_mention",
    "monogenic_primary_mention",
    "monogenic_secondary_mention"
  ],
  "title": "IbdSpecificDiagnosisAnnotation",
  "type": "object"
}